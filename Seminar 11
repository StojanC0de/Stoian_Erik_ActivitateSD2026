#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

//trebuie sa folositi fisierul masini.txt
//sau va creati un alt fisier cu alte date

struct StructuraMasina {
	int id;
	int nrUsi;
	float pret;
	char* model;
	char* numeSofer;
	unsigned char serie;
};
typedef struct StructuraMasina Masina;

Masina citireMasinaDinFisier(FILE* file) {
	char buffer[100];
	char sep[3] = ",\n";
	fgets(buffer, 100, file);
	char* aux;
	Masina m1;
	aux = strtok(buffer, sep);
	m1.id = atoi(aux);
	m1.nrUsi = atoi(strtok(NULL, sep));
	m1.pret = atof(strtok(NULL, sep));
	aux = strtok(NULL, sep);
	m1.model = malloc(strlen(aux) + 1);
	strcpy_s(m1.model, strlen(aux) + 1, aux);

	aux = strtok(NULL, sep);
	m1.numeSofer = malloc(strlen(aux) + 1);
	strcpy_s(m1.numeSofer, strlen(aux) + 1, aux);

	m1.serie = *strtok(NULL, sep);
	return m1;
}

void afisareMasina(Masina masina) {
	printf("Id: %d\n", masina.id);
	printf("Nr. usi : %d\n", masina.nrUsi);
	printf("Pret: %.2f\n", masina.pret);
	printf("Model: %s\n", masina.model);
	printf("Nume sofer: %s\n", masina.numeSofer);
	printf("Serie: %c\n\n", masina.serie);
}

//1. 
// structuri necesare
//dorim stocarea unui graf intr-o lista de liste
//astfel avem nod ListaPrincipala si NodListaSecundara
typedef struct NodListaPrincipala NodListaPrincipala;
typedef struct NodListaSecundara NodListaSecundara;
struct NodListaSecundara {
    NodListaPrincipala* nod;   // spre ce masina pointeaza vecinul
    NodListaSecundara* next;   // urmatorul vecin
};
struct NodListaPrincipala {
    Masina masina;             // datele masinii
    NodListaSecundara* vecini; // lista vecinilor sai
    NodListaPrincipala* next;  // urmatoarea masina din graf
};
//2.
//functii de inserare in liste
//si in principala si in secundara

void inserareNodPrincipal(NodListaPrincipala** lista, Masina masina) {
    NodListaPrincipala* nou = (NodListaPrincipala*)malloc(sizeof(NodListaPrincipala));
    nou->masina = masina;
    nou->vecini = NULL;
    nou->next = *lista;
    *lista = nou;
}

void inserareNodSecundar(NodListaSecundara** lista, NodListaPrincipala* nod) {
    NodListaSecundara* nou = (NodListaSecundara*)malloc(sizeof(NodListaSecundara));
    nou->nod = nod;
    nou->next = *lista;
    *lista = nou;
}

//3.
//functie de cautarea in lista principala dupa ID
NodListaPrincipala* cautaNodDupaID(NodListaPrincipala* listaPrincipala, int id) {
    NodListaPrincipala* lista = (NodListaPrincipala*)listaPrincipala;
    while(lista) {
        if(lista->masina.id == id)
            return lista;
        lista = lista->next;
    }
    return NULL;
}

//4.
//inserare muchie
void inserareMuchie(NodListaPrincipala* listaPrincipala, int idStart, int idStop) {
	NodListaPrincipala* nodStart = (NodListaPrincipala*)cautaNodDupaID(listaPrincipala, idStart);
    NodListaPrincipala* nodStop = (NodListaPrincipala*)cautaNodDupaID(listaPrincipala, idStop);
    if(nodStart && nodStop){
        inserareNodSecundar(&nodStart->vecini,nodStop);
        inserareNodSecundar(&nodStop->vecini,nodStart);
    }
}


NodListaPrincipala* citireNoduriMasiniDinFisier(const char* numeFisier) {
	FILE* f = fopen(numeFisier, "r");
    NodListaPrincipala* lista = NULL;
    if(f){
        while(!feof(f)){
            Masina m = citireMasinaDinFisier(f);
            inserareNodPrincipal(&lista, m);
        }
        fclose(f);
    }
    return lista;
}

void citireMuchiiDinFisier(NodListaPrincipala* listaPrincipala, const char* numeFisier) {
    FILE* f = fopen(numeFisier, "r");
    if (f) {
        int idStart, idStop;
        while (fscanf(f,"%d %d",&idStart,&idStop) == 2) {
            inserareMuchie(listaPrincipala,idStart,idStop);
        }
        fclose(f);
    }
}

void afisareListaVecini(NodListaPrincipala* graf, int id) {
    NodListaPrincipala* temp = cautaNodDupaID(graf, id);
    NodListaSecundara* cap = temp->vecini;
    while (cap) {
        afisareMasina(cap->nod->masina);
        cap = cap->next;
    }
}

void dezalocareNoduriGraf(void* listaPrincipala) {
	NodListaPrincipala* lista = (NodListaPrincipala*) listaPrincipala;
    while(lista) {
        NodListaSecundara* vecin = lista->vecini;
        while (vecin) {
            NodListaSecundara* vecinAux = vecin;
            vecin = vecin->next;
            free(vecinAux);
        }
        free(lista->masina.model);
        free(lista->masina.numeSofer);
        NodListaPrincipala* listaAux = lista;
        lista = lista->next;
        free(listaAux);
    }
}

int main() {
	NodListaPrincipala* lista = (NodListaPrincipala*)citireNoduriMasiniDinFisier("masini.txt");
    citireMuchiiDinFisier(lista, "muchii.txt");
    afisareListaVecini(lista, 3);
    NodListaPrincipala* nod = lista;
    while(nod) {
        afisareMasina(nod->masina);
        printf("Vecini: \n");
        NodListaSecundara* vecin = nod->vecini;
        while(vecin) {
            printf(" -> ID: %d\n",vecin->nod->masina.id);
            vecin = vecin->next;
        }
        printf("\n");
        nod = nod->next;
    }
    dezalocareNoduriGraf(lista);
    return 0;
}